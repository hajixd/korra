{
  "id": "momentum",
  "name": "Momentum",
  "aliases": [
    "trend continuation",
    "breakout momentum",
    "impulse continuation"
  ],
  "description": "if htf_bias == trend && breakout_retest_valid && expansion_confirms then execute_continuation()",
  "entry": {
    "context": [
      "bias := htf_impulse_direction || session_open_drive_direction",
      "levels := { breakout_base, retest_extreme, liquidity_target }",
      "require hold_outside(broken_range) before trigger_check"
    ],
    "setup": [
      "setup_valid := compression_near(breakout_level) || shallow_pullback_after_impulse",
      "retest_valid := close_back_inside_range == false && rejection_depth <= allowed_retest",
      "flow_valid := consecutive_closes_in_bias >= 2"
    ],
    "trigger": [
      "long_entry when price > retest_high; short_entry when price < retest_low",
      "continuation_candle_entry only_if candle_body_close beyond trigger_level",
      "skip if trigger_candle_range > 1.0 * avg_recent_range"
    ],
    "confirmation": [
      "confirm expansion_range > avg_recent_expansion",
      "confirm volume_up || tape_speed_up at trigger_level",
      "confirm structure_holds(reclaimed_level)"
    ],
    "invalidation": [
      "invalidate if price_rotates_back_inside(prior_range)",
      "invalidate if retest_close crosses breakout_base",
      "invalidate if session_impulse_fades && divergence_detected"
    ],
    "noTrade": [
      "skip if high_impact_news inside entry_window",
      "skip if higher_timeframe_opposition <= target_distance",
      "skip if spread_wide || trigger_close_through == false"
    ]
  },
  "exit": {
    "stopLoss": [
      "stop := beyond(retest_extreme || breakout_base)",
      "if structure_loose then stop := far_side(compression_box)",
      "abort_trade if stop_distance > planned_max_risk"
    ],
    "takeProfit": [
      "tp1 := first_extension || nearest_liquidity",
      "tp2 := session_extreme || measured_move when continuation_clean",
      "do_not_expand_target_after_fill := true"
    ],
    "timeExit": [
      "exit if follow_through_missing for 3..6 execution_candles",
      "reduce_size before low_liquidity_handoff",
      "no_carry_on_scalp_breakout_into_dead_hours := true"
    ],
    "earlyExit": [
      "exit_early if full_candle_closes_back_inside(range)",
      "exit_early if counter_impulse_body > entry_candle_body",
      "exit_early if breakout_level_fails_on_next_retest"
    ]
  }
}
