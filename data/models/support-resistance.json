{
  "id": "support-resistance",
  "name": "Support / Resistance",
  "aliases": [
    "support resistance",
    "s/r",
    "level reaction"
  ],
  "description": "Level reaction model that trades when price is sitting at support or resistance, the reversal candle is there, and the local range is large enough.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when price is near support, a bullish reversal prints, and the local range is large enough.",
      "Short when price is near resistance, a bearish reversal prints, and the local range is large enough."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": []
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx entryChecklist() fallback",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "Price is sitting near support",
            "when": {
              "feature": "nearSupport"
            }
          },
          {
            "label": "A bullish reversal has printed",
            "when": {
              "feature": "bullishReversal"
            }
          },
          {
            "label": "The local range is large enough",
            "when": {
              "feature": "sufficientRange"
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "Price is sitting near resistance",
            "when": {
              "feature": "nearResistance"
            }
          },
          {
            "label": "A bearish reversal has printed",
            "when": {
              "feature": "bearishReversal"
            }
          },
          {
            "label": "The local range is large enough",
            "when": {
              "feature": "sufficientRange"
            }
          }
        ]
      }
    }
  }
}
