{
  "id": "mean-reversion",
  "name": "Mean Reversion",
  "aliases": [
    "fade the extreme",
    "reversion fade",
    "stretch reversal"
  ],
  "description": "if price_is_stretched && rejection_prints && value_reclaim_confirms then fade_back_to_mean()",
  "entry": {
    "context": [
      "mean_refs := { session_mean, vwap, prior_swing_extremes }",
      "only_fade when price_at(liquidity_zone || deviation_band)",
      "prefer first_clean_rejection_after_sweep == true"
    ],
    "setup": [
      "setup_valid := tag(outer_band || prior_extreme || deviation_threshold)",
      "rejection_valid := wick_rejection || failed_auction_at_extreme",
      "exhaustion_valid := closes_stop_extending_in_trend"
    ],
    "trigger": [
      "entry when price_reclaims(prior_range) after sweep",
      "alt_trigger := break(rejection_structure_high_low)",
      "scale_only if rejection_structure tightens_invalidation"
    ],
    "confirmation": [
      "confirm displacement_from_mean >= required_stretch",
      "confirm failed_breakout_behavior at extreme",
      "confirm path_to_mean is not immediately_blocked"
    ],
    "invalidation": [
      "invalidate if price_accepts_outside(deviation_zone)",
      "invalidate if trend_accelerates_after_rejection",
      "invalidate if new_session_expansion resets_regime"
    ],
    "noTrade": [
      "skip if high_impact_news just_changed_regime",
      "skip if distance_to_mean < minimum_reward",
      "skip if fading_multi_timeframe_impulse without exhaustion"
    ]
  },
  "exit": {
    "stopLoss": [
      "stop := beyond(sweep_extreme || deviation_band)",
      "keep stop_outside(noise_zone); never_inside(rejection_wick_midpoint)",
      "abort_trade if invalidation_distance > planned_max_risk"
    ],
    "takeProfit": [
      "tp1 := local_mean || vwap || range_mid",
      "tp2 := opposite_side_of_balance when reversal_strengthens",
      "lock_partials_fast once mean_is_reclaimed"
    ],
    "timeExit": [
      "exit if reversion_missing for 2..5 candles after fill",
      "flatten before session_reopen if setup_is_session_specific",
      "no_hold once range_regime_disappears := true"
    ],
    "earlyExit": [
      "exit_early if price_reclaims_extreme_and_holds",
      "exit_early if mean_tagged && continuation_through_balance == false",
      "exit_early if fresh_impulse_candle invalidates_rejection"
    ]
  }
}
