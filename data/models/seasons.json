{
  "id": "seasons",
  "name": "Seasons",
  "aliases": [
    "seasonality",
    "calendar flow",
    "cycle bias"
  ],
  "description": "Cycle model that trades only when the season bucket has just changed, the 30 over 200 EMA bias still agrees, and the oscillator is not already stretched.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when the season bucket has just turned to summer, the 30 EMA is above the 200 EMA, and the oscillator is not already above 60.",
      "Short when the season bucket has just turned to winter, the 30 EMA is below the 200 EMA, and the oscillator is not already below 40."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": [
      "Long exit when the season bucket is no longer summer.",
      "Short exit when the season bucket is no longer winter."
    ]
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx modelEntryGate() and chooseExit()",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "The season bucket has just turned to summer",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "summer"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "summer"
                  ]
                }
              ]
            }
          },
          {
            "label": "The 30 EMA is above the 200 EMA",
            "when": {
              "feature": "upTrendBase"
            }
          },
          {
            "label": "The normalized oscillator is not above 60",
            "when": {
              "not": {
                "feature": "normUp"
              }
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The season bucket has just turned to winter",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "winter"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "winter"
                  ]
                }
              ]
            }
          },
          {
            "label": "The 30 EMA is below the 200 EMA",
            "when": {
              "feature": "downTrendBase"
            }
          },
          {
            "label": "The normalized oscillator is not below 40",
            "when": {
              "not": {
                "feature": "normDown"
              }
            }
          }
        ]
      }
    },
    "exit": {
      "long": {
        "checks": [
          {
            "label": "The season bucket is no longer summer",
            "when": {
              "neq": [
                "seasonBucket",
                "summer"
              ]
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The season bucket is no longer winter",
            "when": {
              "neq": [
                "seasonBucket",
                "winter"
              ]
            }
          }
        ]
      }
    }
  }
}
