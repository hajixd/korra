{
  "id": "seasons",
  "name": "Seasons",
  "aliases": [
    "seasonality",
    "calendar flow",
    "cycle bias"
  ],
  "description": "Cycle model that trades only when the market enters summer or winter, the 30 over 200 EMA bias confirms that direction, and the oscillator is not already overextended.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when the market enters summer, the 30 EMA is above the 200 EMA, and the oscillator is not already overbought.",
      "Short when the market enters winter, the 30 EMA is below the 200 EMA, and the oscillator is not already oversold."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": [
      "Long exit when the market is no longer in summer.",
      "Short exit when the market is no longer in winter."
    ]
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx modelEntryGate() and chooseExit()",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "Enter summer",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "summer"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "summer"
                  ]
                }
              ]
            }
          },
          {
            "label": "Up trend",
            "when": {
              "feature": "upTrendBase"
            }
          },
          {
            "label": "Not overbought",
            "when": {
              "not": {
                "feature": "normUp"
              }
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "Enter winter",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "winter"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "winter"
                  ]
                }
              ]
            }
          },
          {
            "label": "Down trend",
            "when": {
              "feature": "downTrendBase"
            }
          },
          {
            "label": "Not oversold",
            "when": {
              "not": {
                "feature": "normDown"
              }
            }
          }
        ]
      }
    },
    "exit": {
      "long": {
        "checks": [
          {
            "label": "The season bucket is no longer summer",
            "when": {
              "neq": [
                "seasonBucket",
                "summer"
              ]
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The season bucket is no longer winter",
            "when": {
              "neq": [
                "seasonBucket",
                "winter"
              ]
            }
          }
        ]
      }
    }
  }
}
