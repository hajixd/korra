{
  "id": "seasons",
  "name": "Seasons",
  "aliases": [
    "seasonality",
    "calendar flow",
    "cycle bias"
  ],
  "description": "Cycle model that trades only when the season bucket has just changed and the base trend still agrees.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when the season bucket has just turned to summer, the base trend is up, and the market is not already overbought.",
      "Short when the season bucket has just turned to winter, the base trend is down, and the market is not already oversold."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": [
      "Long exit when the season bucket is no longer summer.",
      "Short exit when the season bucket is no longer winter."
    ]
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx modelEntryGate() and chooseExit()",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "The season bucket has just turned to summer",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "summer"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "summer"
                  ]
                }
              ]
            }
          },
          {
            "label": "Trend is already up",
            "when": {
              "feature": "upTrendBase"
            }
          },
          {
            "label": "The market is not already overbought",
            "when": {
              "not": {
                "feature": "normUp"
              }
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The season bucket has just turned to winter",
            "when": {
              "all": [
                {
                  "eq": [
                    "seasonBucket",
                    "winter"
                  ]
                },
                {
                  "neq": [
                    "prevSeasonBucket",
                    "winter"
                  ]
                }
              ]
            }
          },
          {
            "label": "Trend is already down",
            "when": {
              "feature": "downTrendBase"
            }
          },
          {
            "label": "The market is not already oversold",
            "when": {
              "not": {
                "feature": "normDown"
              }
            }
          }
        ]
      }
    },
    "exit": {
      "long": {
        "checks": [
          {
            "label": "The season bucket is no longer summer",
            "when": {
              "neq": [
                "seasonBucket",
                "summer"
              ]
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The season bucket is no longer winter",
            "when": {
              "neq": [
                "seasonBucket",
                "winter"
              ]
            }
          }
        ]
      }
    }
  }
}
