{
  "id": "time-of-day",
  "name": "Time of Day",
  "aliases": [
    "session flow",
    "session timing",
    "intraday clock edge"
  ],
  "description": "Session bucket model that trades when the day or night state has just flipped and the 30 over 200 EMA bias points the same way.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when the time bucket has just flipped to day and the 30 EMA is above the 200 EMA.",
      "Short when the time bucket has just flipped to night and the 30 EMA is below the 200 EMA."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": [
      "Long exit when the time bucket is no longer day.",
      "Short exit when the time bucket is no longer night."
    ]
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx modelEntryGate() and chooseExit()",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "The time bucket has just flipped to day",
            "when": {
              "all": [
                {
                  "eq": [
                    "timeBucket",
                    "day"
                  ]
                },
                {
                  "neq": [
                    "prevTimeBucket",
                    "day"
                  ]
                }
              ]
            }
          },
          {
            "label": "The 30 EMA is above the 200 EMA",
            "when": {
              "feature": "upTrendBase"
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The time bucket has just flipped to night",
            "when": {
              "all": [
                {
                  "eq": [
                    "timeBucket",
                    "night"
                  ]
                },
                {
                  "neq": [
                    "prevTimeBucket",
                    "night"
                  ]
                }
              ]
            }
          },
          {
            "label": "The 30 EMA is below the 200 EMA",
            "when": {
              "feature": "downTrendBase"
            }
          }
        ]
      }
    },
    "exit": {
      "long": {
        "checks": [
          {
            "label": "The time bucket is no longer day",
            "when": {
              "neq": [
                "timeBucket",
                "day"
              ]
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The time bucket is no longer night",
            "when": {
              "neq": [
                "timeBucket",
                "night"
              ]
            }
          }
        ]
      }
    }
  }
}
