{
  "id": "time-of-day",
  "name": "Time of Day",
  "aliases": [
    "session flow",
    "session timing",
    "intraday clock edge"
  ],
  "description": "Session bucket model that trades when the day or night bucket has just flipped and the base trend agrees.",
  "entry": {
    "context": [],
    "setup": [],
    "trigger": [
      "Long when the time bucket has just flipped to day and the base trend is up.",
      "Short when the time bucket has just flipped to night and the base trend is down."
    ],
    "confirmation": [],
    "invalidation": [],
    "noTrade": []
  },
  "exit": {
    "stopLoss": [],
    "takeProfit": [],
    "timeExit": [],
    "earlyExit": [
      "Long exit when the time bucket is no longer day.",
      "Short exit when the time bucket is no longer night."
    ]
  },
  "backtest": {
    "source": "AI.zip /src/App.tsx modelEntryGate() and chooseExit()",
    "entry": {
      "long": {
        "checks": [
          {
            "label": "The time bucket has just flipped to day",
            "when": {
              "all": [
                {
                  "eq": [
                    "timeBucket",
                    "day"
                  ]
                },
                {
                  "neq": [
                    "prevTimeBucket",
                    "day"
                  ]
                }
              ]
            }
          },
          {
            "label": "Trend is already up",
            "when": {
              "feature": "upTrendBase"
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The time bucket has just flipped to night",
            "when": {
              "all": [
                {
                  "eq": [
                    "timeBucket",
                    "night"
                  ]
                },
                {
                  "neq": [
                    "prevTimeBucket",
                    "night"
                  ]
                }
              ]
            }
          },
          {
            "label": "Trend is already down",
            "when": {
              "feature": "downTrendBase"
            }
          }
        ]
      }
    },
    "exit": {
      "long": {
        "checks": [
          {
            "label": "The time bucket is no longer day",
            "when": {
              "neq": [
                "timeBucket",
                "day"
              ]
            }
          }
        ]
      },
      "short": {
        "checks": [
          {
            "label": "The time bucket is no longer night",
            "when": {
              "neq": [
                "timeBucket",
                "night"
              ]
            }
          }
        ]
      }
    }
  }
}
