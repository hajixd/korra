# MetaApi server token (required for copy trading)
METAAPI_API_TOKEN=

# Optional: custom encryption secret for stored account passwords
COPY_TRADING_ENCRYPTION_KEY=

# Optional: cap how many copy-trade accounts can be added from UI
# default is 100 if unset
COPYTRADE_MAX_ACCOUNTS=100

# Optional: worker polling interval in milliseconds
COPY_TRADING_LOOP_MS=15000

# Firebase client app (required for login/create-account/profile features)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
